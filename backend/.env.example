# ===================================
# ENVIRONMENT VARIABLES - COPY KE .env
# ===================================

# GMAIL CONFIGURATION
# 1. Gunakan email Gmail Anda
# 2. Buat App Password: https://myaccount.google.com/apppasswords
#    - Pilih "Mail" dan "Windows Computer"
#    - Copy password yang dihasilkan ke GMAIL_APP_PASSWORD

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# DEVELOPER EMAIL (yang menerima notifikasi pendaftar baru)
DEVELOPER_EMAIL=developer@yourdomain.com

# SERVER
PORT=3000
NODE_ENV=development

# FRONTEND URL (untuk CORS)
FRONTEND_URL=http://localhost:5500
